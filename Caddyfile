# Caddy : reverse proxy + HTTPS automatique (Let's Encrypt).
# Le domaine et l'email ACME viennent de l'environnement (docker-compose).

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip
	# Caddy relaie nativement les WebSockets (Socket.IO) — rien à ajouter.
	reverse_proxy app:3000
}

poopedex.adzerty.fr {
    encode zstd gzip
    reverse_proxy poopedex-web:80
}

api.poopedex.adzerty.fr {
    encode zstd gzip
    reverse_proxy poopedex-api:3000
}
