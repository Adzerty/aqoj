# ════════════════════════════════════════════════════════════════════════
#  AQOJ — variables d'environnement de PRODUCTION (VPS + Docker Compose)
#  Sur le serveur :  cp .env.production.example .env  puis remplis les valeurs.
#  Le .env sert à la fois à docker-compose (substitution) et à l'app (env_file).
# ════════════════════════════════════════════════════════════════════════

# ───────── Domaine & HTTPS (Caddy) ─────────
DOMAIN=aqoj.exemple.com
ACME_EMAIL=toi@exemple.com

# ───────── PostgreSQL ─────────
POSTGRES_USER=aqoj
POSTGRES_PASSWORD=mets-un-mot-de-passe-fort
POSTGRES_DB=aqoj
# L'app joint la base via le hostname du service Docker "db".
# ⚠️ Le mot de passe doit être IDENTIQUE à POSTGRES_PASSWORD ci-dessus.
DATABASE_URL=postgresql://aqoj:mets-un-mot-de-passe-fort@db:5432/aqoj

# ───────── Auth.js / NextAuth ─────────
# Génère le secret avec :  openssl rand -base64 33
AUTH_SECRET=remplace-moi
AUTH_URL=https://aqoj.exemple.com
NEXTAUTH_URL=https://aqoj.exemple.com
AUTH_TRUST_HOST=true

# ───────── Discord OAuth ─────────
# https://discord.com/developers/applications → ton app → OAuth2
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ───────── Divers ─────────
ENABLE_DEV_GUEST=false
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
